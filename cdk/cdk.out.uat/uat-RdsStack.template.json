       "Fn::ImportValue": "uat-VpcStack:ExportsOutputFnGetAttMoodleVpc895D09D1CidrBlock84532412"
      },
      "Description": "Allow MySQL from VPC",
      "FromPort": 3306,
      "IpProtocol": "tcp",
      "ToPort": 3306
     }
    ],
    "VpcId": {
     "Fn::ImportValue": "uat-VpcStack:ExportsOutputRefMoodleVpc895D09D1476475ED"
