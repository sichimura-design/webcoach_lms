     "Ref": "uatRdsStackMoodleRdsSecret66900E723fdaad7efa858a3daf9490cf0a702aeb"
    },
    "TargetId": {
     "Ref": "MoodleRds4D0949BC"
    },
    "TargetType": "AWS::RDS::DBInstance"
   },
   "Metadata": {
    "aws:cdk:path": "uat-RdsStack/MoodleRds/Secret/Attachment/Resource"
   }
  },
  "MoodleRds4D0949BC": {
