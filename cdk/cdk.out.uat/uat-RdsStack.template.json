   "UpdateReplacePolicy": "Delete",
   "DeletionPolicy": "Delete",
   "Metadata": {
    "aws:cdk:path": "uat-RdsStack/MoodleRds/Secret/Resource"
   }
  },
  "MoodleRdsSecretAttachmentA98A29DD": {
   "Type": "AWS::SecretsManager::SecretTargetAttachment",
