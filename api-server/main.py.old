        limit: 取得件数（デフォルト: 10）

    Returns:
        最終アクセスコース一覧（コース情報付き）
    """
    try:
        courses = crud.get_user_last_accessed_courses(db, userid, limit)
        return courses
    except Exception as e:
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Failed to get last accessed courses: {str(e)}"
        )


