# HTTPS設定 (開発環境でHTTPSを使用する場合)
HTTPS=true
SSL_CRT_FILE=../ssl/cert.pem
SSL_KEY_FILE=../ssl/key.pem

# Environment
NODE_ENV=production
GENERATE_SOURCEMAP=false