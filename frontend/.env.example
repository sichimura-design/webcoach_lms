# Frontend Environment Variables (EC2 Deployment)

# EC2サーバーIP: 15.168.134.84
REACT_APP_MOODLE_URL=http://15.168.134.84
REACT_APP_API_SERVER_URL=http://15.168.134.84:8001
REACT_APP_BFF_URL=http://56.155.42.38
REACT_APP_COGNITO_USER_POOL_ID=ap-northeast-1_xxxxxxxxx
REACT_APP_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ChromaDB経由でのセマンティック検索
