# ローカル開発（npm start）用の環境変数
#
# 完全オフラインのモック環境を既定にする。
# これにより実 Cognito / 実 BFF が無くても npm start だけでアプリが起動し、
# 擬似ログイン済みの状態で画面を確認できる。
#
# 実 BFF / 実 Cognito に接続して開発したい場合は、
# .env.development.local（git 管理外）に以下を書いて上書きする:
#   REACT_APP_ENABLE_MOCKS=false
#   REACT_APP_BFF_URL=...
#   REACT_APP_COGNITO_USER_POOL_ID=...
#   REACT_APP_COGNITO_CLIENT_ID=...
REACT_APP_ENABLE_MOCKS=true
