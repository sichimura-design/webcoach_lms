# Moodle SPA Environment Variables
# このファイルを .env にコピーして、EC2環境に合わせて設定してください

# ========================================
# EC2上のサービスエンドポイント
# ========================================

# Moodle LMS (EC2上で動作)
# EC2サーバーIP: 15.168.134.84
MOODLE_URL=https://15.168.134.84

# API Server (FastAPI, ChromaDB統合)
# EC2上のFastAPIサーバーURL
API_SERVER_URL=https://15.168.134.84:8001

# BFF Server (Backend for Frontend)
# EC2上で動作
BFF_URL=https://56.155.42.38

# ========================================
# 機能フラグ
# ========================================

# ChromaDBセマンティック検索の有効化
CHROMADB_ENABLED=true

# 開発モード
NODE_ENV=production

# ========================================
# Moodle Web Service設定
# ========================================

# Moodle Web Service Token
# Moodleの管理画面から発行したトークンを設定
# サイト管理 > プラグイン > Web services > トークンの管理
MOODLE_TOKEN=your_moodle_webservice_token_here

# ========================================
# オプション設定
# ========================================

# フロントエンドのポート（デフォルト: 3000）
FRONTEND_PORT=3000

# BFFサーバーのポート（デフォルト: 3001）
BFF_PORT=3001

# ログレベル (debug, info, warn, error)
LOG_LEVEL=info

# ========================================
# HTTPS設定（フロントエンドのみ）
# ========================================

# フロントエンド開発サーバーでHTTPSを有効化
HTTPS=true

# SSL証明書のパス（ssl/ディレクトリからの相対パス）
SSL_CRT_FILE=../ssl/cert.pem
SSL_KEY_FILE=../ssl/key.pem
