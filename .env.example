# ============================================
# Moodle Docker Environment Configuration
# ============================================
#
# IMPORTANT: このファイルをコピーして .env を作成してください
# cp .env.example .env
#
# その後、各値を環境に合わせて設定してください
# ============================================

# ============================================
# Network Configuration
# ============================================

# EC2 Public IP Address or Domain
# Get your EC2 public IP: curl -s http://169.254.169.254/latest/meta-data/public-ipv4
PUBLIC_IP=localhost

# Moodle URL (Docker network internal)
MOODLE_URL=http://moodle-app:8080

# API Server URL (Docker network internal)
API_SERVER_URL=http://api-server:8001

# Node Environment (development | staging | production)
NODE_ENV=production

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# ============================================
# Security Secrets
# ============================================

# Session Secret (REQUIRED - generate with: openssl rand -base64 32)
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET

# Anthropic API Key (REQUIRED for AI features)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Content Token Secret (REQUIRED - generate with: openssl rand -hex 32)
CONTENT_TOKEN_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET

# Internal API Key (REQUIRED - generate with: openssl rand -base64 32)
# Used for service-to-service authentication
INTERNAL_API_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET

# ============================================
# Moodle Configuration
# ============================================

# Moodle Language Configuration
# Options: ja (Japanese), en (English)
MOODLE_LANG=ja

# Moodle Service Account (REQUIRED)
# BFF uses this account for all Moodle API calls
MOODLE_SERVICE_USERNAME=admin
MOODLE_SERVICE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MOODLE_SERVICE_NAME=moodle-api-service

# ============================================
# AWS Cognito Configuration
# ============================================

# Cognito User Pool ID (REQUIRED for JWT authentication)
COGNITO_USER_POOL_ID=ap-northeast-1_XXXXXXXXX

# Cognito Client ID (REQUIRED)
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# AWS Region
COGNITO_REGION=ap-northeast-1

# ============================================
# AWS S3 Configuration
# ============================================

# S3 Bucket Name (REQUIRED for file uploads)
S3_BUCKET_NAME=your-bucket-name

# CloudFront Domain (REQUIRED for serving uploaded files)
CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# ============================================
# Vector Database Configuration
# ============================================

# Vector Database Type
# Options: chromadb (default), faiss, pgvector
VECTOR_DB_ENV=faiss

# FAISS Cache Directory (for FAISS only)
FAISS_CACHE_DIR=/tmp/faiss_cache

# AWS Region for S3 (for FAISS S3 backup)
AWS_REGION=ap-northeast-1

# RAG Similarity Threshold (0.0 - 1.0)
# AIコーチが参照元を返す類似度の閾値（デフォルト: 0.9 = 90%）
# この値以上の類似度のソースのみがレスポンスに含まれます
RAG_SIMILARITY_THRESHOLD=0.9

# ============================================
# Database Configuration (REQUIRED if using RDS)
# ============================================
# If using external RDS instead of local MySQL:

MOODLE_DB_HOST=your-rds-endpoint.rds.amazonaws.com
MOODLE_DB_PORT=3306
MOODLE_DB_USER=moodleuser
MOODLE_DB_PASSWORD=CHANGE_ME_STRONG_RDS_PASSWORD
MOODLE_DB_NAME=moodle

# Moodle Admin Account (for initial setup)
MOODLE_ADMIN_USERNAME=admin
MOODLE_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
MOODLE_ADMIN_EMAIL=admin@example.com
MOODLE_SITE_NAME=My Moodle Site

# ============================================
# Redis Configuration (Optional)
# ============================================
# For session storage and rate limiting:

# REDIS_URL=redis://your-redis-host:6379
# REDIS_HOST=your-redis-host
# REDIS_PORT=6379

# ============================================
# Logging Configuration (Optional)
# ============================================

# Log Level (debug | info | warn | error)
# LOG_LEVEL=info

# Enable API Documentation (true | false)
# Set to false in production
# ENABLE_DOCS=false
