{
  "name": "cdk-uat",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "deploy:all": "node_modules/.bin/cdk deploy --all --app 'npx ts-node --prefer-ts-exts bin/uat-app.ts' --require-approval never",
    "diff:all": "node_modules/.bin/cdk diff --all --app 'npx ts-node --prefer-ts-exts bin/uat-app.ts'",
    "destroy:all": "node_modules/.bin/cdk destroy --all --app 'npx ts-node --prefer-ts-exts bin/uat-app.ts'"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "aws-cdk": "^2.1118.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.236.0",
    "constructs": "^10.0.0"
  }
}
